# Firebase Admin runtime configuration
FIREBASE_PROJECT_ID=demo-mailmeilmheilmueil
FIREBASE_SERVICE_ACCOUNT_JSON=
GOOGLE_APPLICATION_CREDENTIALS=

# Firebase browser configuration (public build-time values)
VITE_FIREBASE_PROJECT_ID=demo-mailmeilmheilmueil
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_APP_ID=

# Local emulator-only settings; leave unset in production
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
VITE_USE_FIREBASE_EMULATOR=true

# Local SMTP/API defaults
SMTP_PORT=2525
API_PORT=8787

# AI analysis provider

# Heroku: set AI_PROVIDER=openai and provide AI_API_KEY.
# DigitalOcean Codex: leave AI_PROVIDER and AI_API_KEY empty.
AI_PROVIDER=
AI_MODEL=gpt-5.4-mini
AI_BASE_URL=
AI_API_KEY=
# Set true for HTTPS production cookies
IMAP_COOKIE_SECURE=false
