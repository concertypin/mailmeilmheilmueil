    "scripts": {
        "dev": "pnpm dev:stack",
        "dev:client": "vite",
        "dev:server": "tsx server/src/main.ts",
        "dev:stack": "concurrently --kill-others-on-fail --names client,server \"pnpm dev:client\" \"pnpm dev:server\"",
        "build": "vite build",
        "heroku-postbuild": "vite build --mode heroku",
        "start": "tsx server/src/main.ts",
        "start:sync": "tsx server/src/sync-main.ts",
        "format": "prettier --write . --cache --list-different",
        "lint": "oxlint .",
        "postinstall": "pnpm exec simple-git-hooks",
        "preview": "vite preview",
        "pre-commit": "pnpm run format && pnpm run lint && git add -u",
        "test": "node --experimental-default-config-file node_modules/vitest/vitest.mjs run",
        "emulators": "firebase emulators:start --only firestore --project demo-mailmeilmheilmueil"
    },
    "engines": {
        "node": ">=26"
    },
    "dependencies": {
        "@ai-sdk/openai": "^4.0.17",
        "@hono/node-server": "^2.0.10",
        "@phosphor-icons/react": "^2.1.10",
        "ai": "^7.0.31",
        "ai-sdk-provider-codex-cli": "^2.1.1",
        "dotenv": "^17.4.2",
        "firebase": "^12.16.0",
        "firebase-admin": "^14.2.0",
        "hono": "^4.12.31",
        "imapflow": "^1.4.7",
        "node-html-parser": "^9.0.0",
        "postal-mime": "^2.7.5",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "tsx": "^4.23.1",
        "wouter": "^3.10.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.3.2",
        "@testing-library/jest-dom": "^7.0.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@types/node": "^26.1.1",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "@vitest/coverage-v8": "^4.1.10",
        "agentation": "^3.0.2",
        "concurrently": "^10.0.3",
        "cross-env": "^10.1.0",
        "daisyui": "^5.6.18",
        "firebase-tools": "^15.24.0",
        "globals": "^17.7.0",
        "jsdom": "^29.1.1",
        "oxlint": "^1.73.0",
        "oxlint-tsgolint": "^0.24.0",
        "postcss": "^8.5.16",
        "prettier": "^3.9.5",
        "simple-git-hooks": "^2.13.1",
        "tailwindcss": "^4.3.2",
        "typescript": "~7.0.2",
        "vite": "^8.1.4",
        "vitest": "^4.1.10"
    },
    "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a"
